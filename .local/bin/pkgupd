#!/bin/bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: pkgupd

Apply the repository's locked Nix flake to the dotfiles package profile.
This command does not update flake.lock or the host operating system.
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "Error: Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

resolve_script_path() {
    local path=$1
    local target

    if [ -L "$path" ]; then
        target=$(readlink "$path")
        case "$target" in
            /*) path=$target ;;
            *) path=$(dirname "$path")/$target ;;
        esac
    fi
    printf '%s/%s\n' \
        "$(cd "$(dirname "$path")" && pwd)" \
        "$(basename "$path")"
}

load_nix_environment() {
    local profile_script

    for profile_script in \
        /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
        "$HOME/.nix-profile/etc/profile.d/nix.sh"; do
        if [ -r "$profile_script" ]; then
            # shellcheck disable=SC1090
            . "$profile_script"
            break
        fi
    done
}

script_path=$(resolve_script_path "$0")
repo_root=$(cd "$(dirname "$script_path")/../.." && pwd)
profile=${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/nix-profile
nix_args=(--extra-experimental-features "nix-command flakes")

load_nix_environment
command -v nix >/dev/null 2>&1 || {
    echo "Error: Nix is not installed. Run $repo_root/setup.sh first." >&2
    exit 1
}
if [ ! -e "$profile" ] && [ ! -L "$profile" ]; then
    echo "Error: Dotfiles Nix profile not found. Run $repo_root/setup.sh first." >&2
    exit 1
fi

echo "Applying the locked Nix package set..."
nix "${nix_args[@]}" profile upgrade \
    --profile "$profile" \
    --all \
    --no-write-lock-file
